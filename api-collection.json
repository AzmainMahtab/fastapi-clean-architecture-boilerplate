        {
          "name": "PATCH /users/{uuid}/status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/0192b400-c6d4-7a3f-9e12-f8a1b2c3d4e5/status",
              "host": ["{{baseUrl}}"],
              "path": ["users", "0192b400-c6d4-7a3f-9e12-f8a1b2c3d4e5", "status"]
            },
            "description": "Update a user's account status.\n\nAllowed status values: `pending_verification`, `active`, `suspended`.\n\nNote: `inactive` and `deleted` statuses are set automatically by the delete/prune endpoints — they cannot be set directly here."
          },
          "response": [
            {
              "name": "200 — Success",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"status\": \"success\",\n  \"statusCode\": 200,\n  \"data\": {\n    \"uuid\": \"0192b400-c6d4-7a3f-9e12-f8a1b2c3d4e5\",\n    \"email\": \"user@example.com\",\n    \"username\": \"johndoe\",\n    \"phone_number\": \"+1234567890\",\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"status\": \"active\",\n    \"created_at\": \"2026-05-01T10:30:00Z\",\n    \"updated_at\": \"2026-05-16T09:00:00Z\"\n  }\n}"
            },
            {
              "name": "404 — User not found",
              "status": "Not Found",
