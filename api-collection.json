              "body": "{\n  \"success\": false,\n  \"status\": \"fail\",\n  \"statusCode\": 404,\n  \"errors\": [\n    {\n      \"code\": \"USER_NOT_FOUND\",\n      \"message\": \"User not found.\"\n    }\n  ]\n}"
